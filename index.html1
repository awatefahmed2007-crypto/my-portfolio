<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flora | فلورا — بوتيك الزهور الفاخر</title>
<meta name="description" content="Flora | فلورا — تنسيقات زهور فاخرة، مُركّبة بصمت وحرفية، لمن يفضّل أن يتحدث الجمال بدلاً عنه.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Tajawal:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&display=swap" rel="stylesheet">

<style>
  /* ======================= Design Tokens ======================= */
  :root{
    --bg:#E8E5E0;
    --ink:#262320;
    --ink-soft: rgba(38,35,32,.62);
    --ink-faint: rgba(38,35,32,.38);
    --card:#F2EFEA;
    --line: rgba(38,35,32,.14);
    --line-strong: rgba(38,35,32,.28);
    --gold:#A9824C;
    --gold-deep:#8C6A3A;
    --sage:#4B5240;
    --radius: 2px;
    --ease: cubic-bezier(.65,0,.35,1);
  }

  *{ box-sizing:border-box; }
  html,body{ margin:0; padding:0; }
  body{
    background:var(--bg);
    color:var(--ink);
    font-family:'Tajawal', sans-serif;
    font-weight:400;
    line-height:1.8;
    overflow-x:hidden;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,.amiri{ font-family:'Amiri', serif; font-weight:700; margin:0; }
  p{ margin:0; }
  img{ max-width:100%; display:block; }
  button{ font-family:inherit; cursor:pointer; background:none; border:none; color:inherit; }
  a{ color:inherit; text-decoration:none; }
  :focus-visible{ outline:2px solid var(--gold); outline-offset:3px; }

  .eyebrow{
    display:inline-flex; align-items:center; gap:10px;
    font-size:14.5px; letter-spacing:.12em; color:var(--gold-deep);
    font-weight:500; margin-bottom:18px;
  }
  .eyebrow::before{ content:''; width:22px; height:1px; background:var(--gold); display:inline-block; }

  .wrap{ max-width:1180px; margin:0 auto; padding:0 6vw; }

  /* ======================= Header ======================= */
  .site-header{
    position:fixed; top:0; right:0; left:0; z-index:50;
    display:flex; justify-content:space-between; align-items:center;
    padding:26px 6vw; pointer-events:none;
    mix-blend-mode: difference;
  }
  .site-header .mark{
    display:flex; align-items:baseline; gap:8px; color:#fff;
  }
  .site-header .mark-en{ font-family:'Cormorant Garamond',serif; font-weight:500; font-size:21px; letter-spacing:.05em; }
  .site-header .mark-ar{ font-family:'Amiri',serif; font-weight:700; font-size:14px; opacity:.85; }

  /* ======================= Hero ======================= */
  .hero{
    min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center; position:relative; padding:0 6vw; isolation:isolate; overflow:hidden;
  }
  .hero-scatter{ position:absolute; inset:0; z-index:-1; pointer-events:none; overflow:hidden; }
  .scatter-flower{ position:absolute; pointer-events:none; }
  .hero .eyebrow{ justify-content:center; }
  .hero-title{ display:flex; flex-direction:column; align-items:center; gap:8px; }
  .brand-en{
    font-family:'Cormorant Garamond', serif; font-weight:500;
    font-size:clamp(58px, 11vw, 132px); letter-spacing:.02em; line-height:1; color:var(--ink);
  }
  .brand-ar{
    font-family:'Amiri', serif; font-weight:700;
    font-size:clamp(22px, 3vw, 36px); letter-spacing:.06em; color:var(--ink-soft);
  }
  .hero .sub{
    margin-top:26px; max-width:520px; color:var(--ink-soft);
    font-size:clamp(16.5px,1.8vw,20px); font-weight:300;
  }
  .scroll-cue{
    position:absolute; bottom:42px; display:flex; flex-direction:column; align-items:center; gap:10px;
    color:var(--ink-faint); font-size:12px; letter-spacing:.08em;
  }
  .scroll-cue .line{ width:1px; height:34px; background:var(--ink-faint); position:relative; overflow:hidden; }
  .scroll-cue .line::after{
    content:''; position:absolute; top:0; right:0; left:0; height:10px; background:var(--gold);
    animation: dripLine 2.2s var(--ease) infinite;
  }
  @keyframes dripLine{ 0%{ transform:translateY(-10px); } 100%{ transform:translateY(34px); } }

  /* ======================= Story ======================= */
  .story{
    min-height:100vh; display:flex; align-items:center;
    padding:14vh 6vw;
  }
  .story-grid{
    width:100%; max-width:1180px; margin:0 auto;
    display:grid; grid-template-columns: 1fr 1px 1.15fr; gap:64px; align-items:start;
  }
  .story-grid .divider{ background:var(--line); height:100%; min-height:220px; }
  .story-head h2{ font-size:clamp(38px,5vw,58px); }
  .story-body p{ color:var(--ink-soft); font-size:16px; font-weight:300; margin-bottom:22px; max-width:560px; }
  .story-quote{
    font-family:'Amiri', serif; font-style:italic; font-size:clamp(20px,2.4vw,26px);
    color:var(--ink); margin-top:28px; position:relative; padding-right:22px; max-width:520px;
  }
  .story-quote::before{ content:''; position:absolute; right:0; top:6px; bottom:6px; width:2px; background:var(--gold); }
  .reveal{ opacity:0; transform:translateY(28px); }

  /* ======================= Horizontal product section ======================= */
  .horizontal-section{
    position:relative; height:100vh; overflow:hidden; background:var(--bg);
  }
  .h-ui{
    position:absolute; inset:0; z-index:5; pointer-events:none;
  }
  .h-ui .h-eyebrow{
    position:absolute; top:48px; right:6vw; pointer-events:auto;
  }
  .h-progress{
    position:absolute; bottom:88px; right:8vw; left:8vw; height:1px;
  }
  .h-progress-track{ position:absolute; inset:0; background:var(--line); }
  .h-progress-fill{
    position:absolute; inset:0; background:var(--gold);
    transform-origin:right center; transform:scaleX(0);
  }
  .h-progress-dot{
    position:absolute; top:50%; width:8px; height:8px; border-radius:50%;
    background:var(--gold); transform:translate(50%,-50%); left:100%;
    transition:left .05s linear;
  }
  .h-dots{
    position:absolute; bottom:50px; right:8vw; left:8vw;
    display:flex; justify-content:space-between; font-size:12px; color:var(--ink-faint);
    letter-spacing:.05em; pointer-events:none;
  }
  .h-dots span{ transition:color .3s var(--ease); }
  .h-dots span.active{ color:var(--gold-deep); font-weight:500; }

  .product-track{
    height:100%; display:flex; will-change:transform;
  }
  .product-panel{
    flex:0 0 100vw; width:100vw; height:100%;
    display:flex; align-items:center; justify-content:center;
    padding:0 6vw;
  }
  .panel-inner{
    width:100%; max-width:1180px; margin:0 auto;
    display:flex; align-items:center; gap:6vw;
  }
  .image-frame{
    background:var(--card); padding:18px; border:1px solid var(--line);
    width:min(40vw, 440px); flex-shrink:0;
  }
  .image-frame .square{ width:100%; aspect-ratio:1/1; overflow:hidden; background:var(--bg); }
  .image-frame .square img{ width:100%; height:100%; object-fit:cover; }

  .panel-text{ flex:1; min-width:0; }
  .panel-num{ font-size:14px; color:var(--gold-deep); letter-spacing:.1em; margin-bottom:14px; display:block; }
  .panel-text h3{ font-size:clamp(30px,4vw,46px); margin-bottom:18px; }
  .panel-text .desc{ color:var(--ink-soft); font-size:15.5px; font-weight:300; max-width:460px; margin-bottom:26px; }
  .panel-price{ font-size:20px; font-weight:500; margin-bottom:22px; }
  .panel-price .cur{ font-size:14px; color:var(--ink-soft); margin-right:6px; }
  .panel-link{
    display:inline-flex; align-items:center; gap:8px; font-size:13.5px;
    color:var(--ink); border-bottom:1px solid var(--line-strong); padding-bottom:4px;
    transition:color .3s var(--ease), border-color .3s var(--ease);
  }
  .panel-link:hover{ color:var(--gold-deep); border-color:var(--gold); }

  /* ======================= Fallback (mobile / reduced motion) grid ======================= */
  body.is-fallback .horizontal-section{ height:auto; overflow:visible; padding:14vh 0 10vh; }
  body.is-fallback .h-ui{ display:none; }
  body.is-fallback .product-track{
    display:grid; grid-template-columns:1fr; gap:64px; width:100% !important; height:auto;
    max-width:560px; margin:0 auto; padding:0 6vw;
  }
  body.is-fallback .product-panel{ flex:none; width:100%; height:auto; padding:0; }
  body.is-fallback .panel-inner{ flex-direction:column; gap:32px; text-align:center; align-items:center; }
  body.is-fallback .image-frame{ width:min(80vw,420px); }
  body.is-fallback .panel-text .desc{ margin-inline:auto; }

  @media (min-width: 1300px){ body.is-fallback .product-track{ max-width:760px; } }

  /* ======================= Contact ======================= */
  .contact{
    min-height:70vh; display:flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center; padding:14vh 6vw;
  }
  .contact h2{ font-size:clamp(34px,5vw,52px); margin-bottom:18px; }
  .contact .sub{ color:var(--ink-soft); font-size:15.5px; font-weight:300; max-width:440px; margin-bottom:46px; }
  .social-row{ display:flex; gap:18px; flex-wrap:wrap; justify-content:center; }
  .social-btn{
    position:relative; overflow:hidden; display:inline-flex; align-items:center; gap:12px;
    padding:18px 34px; border:1px solid var(--ink); font-size:14.5px; letter-spacing:.03em;
    z-index:1;
  }
  .social-btn span{ position:relative; z-index:2; transition:color .4s var(--ease); }
  .social-btn svg{ position:relative; z-index:2; transition:stroke .4s var(--ease), fill .4s var(--ease); }
  .social-btn::before{
    content:''; position:absolute; inset:0; background:var(--ink);
    transform:translateY(101%); transition:transform .45s var(--ease); z-index:1;
  }
  .social-btn:hover::before{ transform:translateY(0); }
  .social-btn:hover span{ color:var(--bg); }
  .social-btn:hover svg{ stroke:var(--bg); }
  .social-btn.whatsapp:hover{ border-color:var(--sage); }
  .social-btn.whatsapp:hover::before{ background:var(--sage); }
  .social-btn.instagram:hover::before{ background:var(--gold-deep); }
  .social-btn.instagram:hover{ border-color:var(--gold-deep); }

  /* ======================= Footer ======================= */
  .site-footer{
    padding:30px 6vw 110px; text-align:center; color:var(--ink-faint); font-size:12.5px;
    border-top:1px solid var(--line);
  }

  /* ======================= Admin floating button ======================= */
  .admin-fab{
    position:fixed; bottom:24px; left:24px; z-index:40;
    display:flex; align-items:center; gap:8px;
    padding:11px 18px; background:rgba(232,229,224,.7); backdrop-filter:blur(6px);
    border:1px solid var(--line); font-size:12.5px; color:var(--ink-soft);
    transition:opacity .35s var(--ease), background .3s var(--ease), color .3s var(--ease);
    opacity:.55;
  }
  .admin-fab:hover{ opacity:1; color:var(--ink); background:var(--card); }

  /* ======================= Modals ======================= */
  .modal-overlay{
    position:fixed; inset:0; z-index:100; display:flex; align-items:center; justify-content:center;
    background:rgba(38,35,32,.55); backdrop-filter:blur(4px); padding:24px;
    opacity:0; visibility:hidden; transition:opacity .3s var(--ease), visibility .3s var(--ease);
  }
  .modal-overlay.open{ opacity:1; visibility:visible; }
  .modal{
    background:var(--bg); width:100%; max-width:420px; padding:40px 36px;
    border:1px solid var(--line); position:relative; transform:translateY(16px) scale(.98);
    transition:transform .35s var(--ease);
  }
  .modal-overlay.open .modal{ transform:translateY(0) scale(1); }
  .modal-close{
    position:absolute; top:18px; left:18px; font-size:22px; color:var(--ink-faint); line-height:1;
    width:30px; height:30px; display:flex; align-items:center; justify-content:center;
  }
  .modal-close:hover{ color:var(--ink); }
  .modal-eyebrow{ font-size:12px; letter-spacing:.1em; color:var(--gold-deep); margin-bottom:8px; }
  .modal h3{ font-size:24px; margin-bottom:10px; }
  .modal-desc{ color:var(--ink-soft); font-size:13.5px; font-weight:300; margin-bottom:24px; }
  .modal form{ display:flex; flex-direction:column; gap:14px; }
  .modal label{ font-size:12.5px; color:var(--ink-soft); margin-bottom:-6px; }
  .modal input, .modal textarea{
    width:100%; background:transparent; border:none; border-bottom:1px solid var(--line-strong);
    padding:10px 2px; font-family:'Tajawal',sans-serif; font-size:15px; color:var(--ink);
    resize:none; transition:border-color .3s var(--ease);
  }
  .modal input::placeholder, .modal textarea::placeholder{ color:var(--ink-faint); }
  .modal input:focus, .modal textarea:focus{ border-color:var(--gold); outline:none; }
  .form-error{ color:#9C4A3D; font-size:13px; }
  .btn-primary{
    margin-top:8px; background:var(--ink); color:var(--bg); padding:14px 20px; font-size:14.5px;
    letter-spacing:.03em; transition:background .3s var(--ease);
  }
  .btn-primary:hover{ background:var(--gold-deep); }
  .modal-actions{ display:flex; gap:12px; margin-top:8px; }
  .modal-actions .btn-primary{ flex:1; margin-top:0; }
  .btn-ghost{
    flex:1; border:1px solid var(--line-strong); padding:14px 20px; font-size:14.5px; color:var(--ink-soft);
    transition:border-color .3s var(--ease), color .3s var(--ease);
  }
  .btn-ghost:hover{ border-color:var(--ink); color:var(--ink); }

  /* ======================= Toast ======================= */
  .toast{
    position:fixed; bottom:30px; right:50%; transform:translateX(50%) translateY(20px);
    background:var(--ink); color:var(--bg); padding:14px 28px; font-size:13.5px;
    z-index:110; opacity:0; pointer-events:none; white-space:nowrap;
  }

  @media (max-width: 860px){
    .story-grid{ grid-template-columns:1fr; gap:32px; }
    .story-grid .divider{ display:none; }
  }
</style>
</head>
<body>

<header class="site-header">
  <span class="mark">أزهار الصمت</span>
</header>

<!-- ======================= HERO ======================= -->
<section class="hero" id="hero">
  <span class="eyebrow">بوتيك الزهور الفاخر</span>
  <h1 class="hero-title">أزهار الصمت</h1>
  <p class="sub hero-sub">تنسيقات زهور استثنائية، تُركَّب في صمت، لتُحكى بلا كلمات.</p>
  <div class="scroll-cue"><span>انزل لتكتشف القصة</span><span class="line"></span></div>
</section>

<!-- ======================= STORY ======================= -->
<section class="story" id="story">
  <div class="story-grid">
    <div class="story-head reveal">
      <span class="eyebrow">الفلسفة</span>
      <h2>قصتنا</h2>
    </div>
    <div class="divider"></div>
    <div class="story-body reveal">
      <p>نحن لا نُسرع الجمال. كل باقة تبدأ بصمتٍ طويل، حيث تُختار الأزهار وحدها، بعيدًا عن الضجيج، لتتشكّل تكوينات تشبه أصحابها أكثر مما تشبه السوق.</p>
      <p>في استوديو صغير، بين أصابع حرفية صبورة، تُنسَج كل باقة كقطعة فنية واحدة لا تتكرر؛ تُقدَّم مرّة واحدة، وتُروى طويلاً.</p>
      <p class="story-quote">الجمال الحقيقي لا يحتاج إلى صوت ليُسمع.</p>
    </div>
  </div>
</section>

<!-- ======================= HORIZONTAL PRODUCT SECTION ======================= -->
<section class="horizontal-section" id="horizontalSection">
  <div class="h-ui">
    <span class="eyebrow h-eyebrow">المجموعة</span>
    <div class="h-progress">
      <div class="h-progress-track"></div>
      <div class="h-progress-fill" id="hProgressFill"></div>
      <div class="h-progress-dot" id="hProgressDot"></div>
    </div>
    <div class="h-dots" id="hDots"></div>
  </div>
  <div class="product-track" id="productTrack"></div>
</section>

<!-- ======================= CONTACT ======================= -->
<section class="contact" id="contact">
  <span class="eyebrow">تواصل</span>
  <h2>لنُحضّر باقتك</h2>
  <p class="sub">لكل طلب خاص، نفضّل أن نسمع صوتكم مباشرة.</p>
  <div class="social-row">
    <a class="social-btn whatsapp" href="https://wa.me/96599999999?text=%D9%85%D8%B1%D8%AD%D8%A8%D8%A7%D9%8B%D8%8C%20%D8%A3%D8%B1%D8%AC%D9%88%20%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%81%D8%B3%D8%A7%D8%B1%20%D8%B9%D9%86%20%D8%A8%D8%A7%D9%82%D8%A9%20%D9%85%D9%86%20%D8%A3%D8%B2%D9%87%D8%A7%D8%B1%20%D8%A7%D9%84%D8%B5%D9%85%D8%AA" target="_blank" rel="noopener">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20.5 11.9a8.4 8.4 0 1 1-3.6-6.9M20.5 11.9c0 4.6-3.8 8.4-8.4 8.4a8.3 8.3 0 0 1-4.2-1.1L3 20l1-4.6a8.3 8.3 0 0 1-1.2-4.3C2.8 6.5 6.6 2.8 11.2 2.8c2.3 0 4.4.9 5.9 2.5"/><path d="M8.5 9.3c.2-.4.5-.4.8-.4h.5c.2 0 .4 0 .6.4.2.5.7 1.6.7 1.8 0 .1 0 .3-.1.4-.2.2-.3.4-.5.5-.2.2-.3.3-.1.6.6 1 1.3 1.6 2.4 2.1.2.1.4.1.5-.1.2-.2.6-.7.8-.9.2-.2.3-.2.5-.1.3.1 1.6.8 1.9 1 .3.1.4.2.5.3 0 .2 0 .9-.3 1.4-.3.5-1.5 1-2.1 1-.6 0-2-.2-3.8-1.5-1.8-1.3-2.9-3-3.1-3.4-.1-.3-.7-1.1-.7-2 0-.9.5-1.4.7-1.6Z" fill="currentColor" stroke="none"/></svg>
      <span>تواصل عبر الواتساب</span>
    </a>
    <a class="social-btn instagram" href="https://instagram.com/azhar.alsamt" target="_blank" rel="noopener">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1"/></svg>
      <span>حساب الإنستقرام</span>
    </a>
  </div>
</section>

<footer class="site-footer">
  <p>© جميع الحقوق محفوظة — أزهار الصمت ٢٠٢٦</p>
</footer>

<!-- ======================= ADMIN FAB ======================= -->
<button class="admin-fab" id="adminTrigger">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="3"/><path d="M19.4 13.5c.04-.5.04-1 0-1.5l1.9-1.5-2-3.4-2.2.6a7.7 7.7 0 0 0-1.3-.75l-.3-2.3H9.5l-.3 2.3c-.47.2-.9.45-1.3.75l-2.2-.6-2 3.4 1.9 1.5c-.04.5-.04 1 0 1.5l-1.9 1.5 2 3.4 2.2-.6c.4.3.83.55 1.3.75l.3 2.3h4.9l.3-2.3c.47-.2.9-.45 1.3-.75l2.2.6 2-3.4-1.9-1.5Z"/></svg>
  <span>لوحة التحكم</span>
</button>

<!-- ======================= PASSCODE MODAL ======================= -->
<div class="modal-overlay" id="passOverlay">
  <div class="modal pass-modal" role="dialog" aria-modal="true" aria-labelledby="passTitle">
    <button class="modal-close" id="passClose" aria-label="إغلاق النافذة">×</button>
    <p class="modal-eyebrow">دخول مقيّد</p>
    <h3 id="passTitle">الوصول إلى لوحة التحكم</h3>
    <p class="modal-desc">هذه المساحة مخصّصة لفريق أزهار الصمت فقط.</p>
    <form id="passForm">
      <label for="passInput">رمز الدخول</label>
      <input type="password" id="passInput" inputmode="numeric" placeholder="••••" autocomplete="off">
      <p class="form-error" id="passError" hidden>الرمز غير صحيح، حاول مرة أخرى.</p>
      <button type="submit" class="btn-primary">دخول</button>
    </form>
  </div>
</div>

<!-- ======================= PRODUCT FORM MODAL ======================= -->
<div class="modal-overlay" id="productOverlay">
  <div class="modal product-modal" role="dialog" aria-modal="true" aria-labelledby="productTitle">
    <button class="modal-close" id="productClose" aria-label="إغلاق النافذة">×</button>
    <p class="modal-eyebrow">لوحة التحكم</p>
    <h3 id="productTitle">إضافة باقة جديدة</h3>
    <form id="productForm">
      <label for="pName">اسم المنتج</label>
      <input type="text" id="pName" placeholder="مثال: سرّ القمر" required>
      <label for="pPrice">السعر بالدينار الكويتي</label>
      <input type="number" id="pPrice" min="1" step="1" placeholder="مثال: ٥٥" required>
      <label for="pDesc">وصف المنتج</label>
      <textarea id="pDesc" rows="3" placeholder="اكتب وصفًا مميزًا لهذه الباقة..." required></textarea>
      <label for="pImg">رابط الصورة</label>
      <input type="url" id="pImg" placeholder="https://example.com/image.jpg">
      <div class="modal-actions">
        <button type="button" class="btn-ghost" id="productCancel">إلغاء</button>
        <button type="submit" class="btn-primary">حفظ المنتج</button>
      </div>
    </form>
  </div>
</div>

<div class="toast" id="toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script>
(function(){
  gsap.registerPlugin(ScrollTrigger);

  /* ======================= helpers ======================= */
  var ARABIC_DIGITS = ['٠','١','٢','٣','٤','٥','٦','٧','٨','٩'];
  function toArabicNumerals(input){
    return String(input).replace(/[0-9]/g, function(d){ return ARABIC_DIGITS[+d]; });
  }
  var SWATCHES = ['#EFE6DE','#CDD2BD','#D8C9A8','#E3DED5','#D9C7C2','#C8CFC0'];
  function swatch(hex){
    var svg = "<svg xmlns='http://www.w3.org/2000/svg' width='1080' height='1080'><rect width='100%' height='100%' fill='"+hex+"'/></svg>";
    return 'data:image/svg+xml;utf8,' + encodeURIComponent(svg);
  }
  function waLink(productName){
    var text = 'مرحبًا، أرغب بالاستفسار عن باقة «' + productName + '»';
    return 'https://wa.me/96599999999?text=' + encodeURIComponent(text);
  }

  /* ======================= product data ======================= */
  var products = [
    {
      name: 'همسة الفجر',
      price: '45',
      desc: 'تكوين هادئ من الفاوانيا البيضاء والورد الفرنسي، يتفتّح ببطء كأول خيط من ضوء الصباح. باقة لمن يفضّل أن يبدأ يومه دون أن يقول كلمة.',
      img: swatch(SWATCHES[0])
    },
    {
      name: 'ظل الياسمين',
      price: '62',
      desc: 'الياسمين العربي يتشابك مع أوراق الأوكالبتوس الفضية في تكوين عميق الظل، دافئ كحكاية تُروى في المساء. لمن يحبّ أن تتسلّل رائحة باقته إلى الذكريات قبل العين.',
      img: swatch(SWATCHES[1])
    },
    {
      name: 'توقيع الذهب',
      price: '78',
      desc: 'أوركيد نادر بلمسات من ورق الذهب الصالح للأكل، في تكوين دراماتيكي يُحفظ لا يُهدى فقط — بل يُعلَن به عن لحظة استثنائية لا تتكرر.',
      img: swatch(SWATCHES[2])
    }
  ];

  var track = document.getElementById('productTrack');
  var dotsWrap = document.getElementById('hDots');
  var progressFill = document.getElementById('hProgressFill');
  var progressDot = document.getElementById('hProgressDot');
  var horizontalSection = document.getElementById('horizontalSection');

  function buildPanel(product, index){
    var panel = document.createElement('div');
    panel.className = 'product-panel';
    panel.innerHTML =
      '<div class="panel-inner">' +
        '<div class="image-frame"><div class="square"><img src="'+product.img+'" width="1080" height="1080" alt="'+product.name+'"></div></div>' +
        '<div class="panel-text">' +
          '<span class="panel-num">' + toArabicNumerals(String(index+1).padStart(2,'0')) + '</span>' +
          '<h3>' + product.name + '</h3>' +
          '<p class="desc">' + product.desc + '</p>' +
          '<p class="panel-price"><span class="cur">د.ك</span>' + toArabicNumerals(product.price) + '</p>' +
          '<a class="panel-link" href="'+waLink(product.name)+'" target="_blank" rel="noopener">استفسار سريع عبر الواتساب ←</a>' +
        '</div>' +
      '</div>';
    return panel;
  }

  function renderAllPanels(){
    track.innerHTML = '';
    products.forEach(function(p, i){ track.appendChild(buildPanel(p, i)); });
  }

  function renderDots(){
    dotsWrap.innerHTML = '';
    products.forEach(function(p, i){
      var span = document.createElement('span');
      span.textContent = toArabicNumerals(String(i+1).padStart(2,'0'));
      if (i === 0) span.classList.add('active');
      dotsWrap.appendChild(span);
    });
  }

  /* ======================= layout mode (horizontal vs fallback) ======================= */
  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var pinTween = null, pinTrigger = null;

  function isFallbackMode(){
    return reduceMotion || window.innerWidth < 768;
  }

  function teardownHorizontalScroll(){
    if (pinTrigger){ pinTrigger.kill(true); pinTrigger = null; }
    if (pinTween){ pinTween.kill(); pinTween = null; }
    gsap.set(track, { clearProps: 'transform' });
  }

  function setupHorizontalScroll(){
    teardownHorizontalScroll();
    var panels = gsap.utils.toArray('.product-panel');
    if (panels.length < 1) return;

    pinTween = gsap.fromTo(track,
      { x: function(){ return -(track.scrollWidth - window.innerWidth); } },
      { x: 0, ease: 'none' }
    );

    pinTrigger = ScrollTrigger.create({
      trigger: horizontalSection,
      start: 'top top',
      end: function(){ return '+=' + (track.scrollWidth - window.innerWidth); },
      pin: true,
      scrub: 1,
      animation: pinTween,
      invalidateOnRefresh: true,
      onUpdate: function(self){ updateProgressUI(self.progress); }
    });
  }

  function updateProgressUI(progress){
    progressFill.style.transform = 'scaleX(' + progress + ')';
    progressDot.style.left = ((1 - progress) * 100) + '%';
    var activeIndex = Math.round(progress * (products.length - 1));
    var dots = dotsWrap.querySelectorAll('span');
    dots.forEach(function(d, i){ d.classList.toggle('active', i === activeIndex); });
  }

  function applyLayoutMode(){
    var fallback = isFallbackMode();
    document.body.classList.toggle('is-fallback', fallback);
    if (fallback){
      teardownHorizontalScroll();
    } else {
      setupHorizontalScroll();
    }
    ScrollTrigger.refresh();
  }

  /* ======================= entrance / scroll-reveal animations ======================= */
  function initEntranceAnimations(){
    if (reduceMotion){
      gsap.set('.reveal', { opacity:1, y:0 });
      gsap.set('.hero-title, .hero-sub, .eyebrow', { opacity:1, y:0 });
      return;
    }

    gsap.timeline({ defaults:{ ease:'power3.out' } })
      .from('.hero .eyebrow', { opacity:0, y:18, duration:.8 })
      .from('.hero-title', { opacity:0, y:26, duration:1 }, '-=.5')
      .from('.hero-sub', { opacity:0, y:18, duration:.8 }, '-=.6')
      .from('.scroll-cue', { opacity:0, duration:.8 }, '-=.4');

    gsap.utils.toArray('.reveal').forEach(function(el){
      gsap.to(el, {
        opacity:1, y:0, duration:1, ease:'power3.out',
        scrollTrigger:{ trigger: el, start:'top 82%' }
      });
    });
  }

  /* ======================= init ======================= */
  renderAllPanels();
  renderDots();
  applyLayoutMode();
  initEntranceAnimations();

  var resizeTimer;
  window.addEventListener('resize', function(){
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(applyLayoutMode, 250);
  });

  /* ======================= toast ======================= */
  var toastEl = document.getElementById('toast');
  var toastTween;
  function showToast(message){
    toastEl.textContent = message;
    if (toastTween) toastTween.kill();
    toastTween = gsap.timeline()
      .to(toastEl, { opacity:1, y:0, duration:.4, ease:'power2.out' })
      .to(toastEl, { opacity:0, y:20, duration:.4, ease:'power2.in', delay:2.2 });
  }

  /* ======================= admin / modal logic ======================= */
  var adminTrigger = document.getElementById('adminTrigger');
  var passOverlay = document.getElementById('passOverlay');
  var passForm = document.getElementById('passForm');
  var passInput = document.getElementById('passInput');
  var passError = document.getElementById('passError');
  var passClose = document.getElementById('passClose');

  var productOverlay = document.getElementById('productOverlay');
  var productForm = document.getElementById('productForm');
  var productClose = document.getElementById('productClose');
  var productCancel = document.getElementById('productCancel');

  function openOverlay(el){ el.classList.add('open'); }
  function closeOverlay(el){ el.classList.remove('open'); }

  adminTrigger.addEventListener('click', function(){
    passError.hidden = true;
    passInput.value = '';
    openOverlay(passOverlay);
    setTimeout(function(){ passInput.focus(); }, 250);
  });

  passClose.addEventListener('click', function(){ closeOverlay(passOverlay); });
  passOverlay.addEventListener('click', function(e){ if (e.target === passOverlay) closeOverlay(passOverlay); });

  passForm.addEventListener('submit', function(e){
    e.preventDefault();
    if (passInput.value === '1234'){
      passError.hidden = true;
      closeOverlay(passOverlay);
      openOverlay(productOverlay);
      setTimeout(function(){ document.getElementById('pName').focus(); }, 250);
    } else {
      passError.hidden = false;
      gsap.fromTo('.pass-modal', { x:-6 }, { x:0, duration:.4, ease:'elastic.out(1,.4)' });
      passInput.value = '';
      passInput.focus();
    }
  });

  productClose.addEventListener('click', function(){ closeOverlay(productOverlay); });
  productCancel.addEventListener('click', function(){ closeOverlay(productOverlay); });
  productOverlay.addEventListener('click', function(e){ if (e.target === productOverlay) closeOverlay(productOverlay); });

  productForm.addEventListener('submit', function(e){
    e.preventDefault();
    var name = document.getElementById('pName').value.trim();
    var price = document.getElementById('pPrice').value.trim();
    var desc = document.getElementById('pDesc').value.trim();
    var imgUrl = document.getElementById('pImg').value.trim();

    if (!name || !price || !desc) return;

    var newProduct = {
      name: name,
      price: price,
      desc: desc,
      img: imgUrl || swatch(SWATCHES[products.length % SWATCHES.length])
    };

    products.push(newProduct);
    addProductToDOM(newProduct);

    productForm.reset();
    closeOverlay(productOverlay);
    showToast('تمت إضافة الباقة بنجاح');
  });

  function addProductToDOM(product){
    var index = products.length - 1;
    var panel = buildPanel(product, index);
    gsap.set(panel, { opacity:0 });
    track.appendChild(panel);
    renderDots();

    if (isFallbackMode()){
      gsap.to(panel, { opacity:1, y:0, duration:.7, ease:'power3.out' });
    } else {
      setupHorizontalScroll();
      gsap.to(panel, { opacity:1, duration:.6, ease:'power2.out', delay:.05 });
    }
    ScrollTrigger.refresh();
  }

  /* close modals with Escape */
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape'){
      closeOverlay(passOverlay);
      closeOverlay(productOverlay);
    }
  });
})();
</script>
</body>
</html>
